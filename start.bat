@echo off
setlocal EnableDelayedExpansion
title Crypto Sentinel вҖ” Launcher
color 0A

echo.
echo  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
echo  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—
echo  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘
echo  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—  в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв•җв•қ    в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘
echo  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘        в–Ҳв–Ҳв•‘   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
echo   в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ        в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ
echo.
echo  AI Market Intelligence Terminal  -  Full Stack Launcher
echo  в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.

set ROOT=c:\Aarav\Code\CyrptoNerve
set BACKEND=%ROOT%\crypto-sentinel
set FRONTEND=%ROOT%\crypto-sentinel-ui
set DB_SCRIPT=%BACKEND%\scripts\init_db.py
set DB_FILE=%BACKEND%\data\crypto_sentinel.db

:: в”Җв”Җ Step 1: Init DB if missing в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo  [1/4] Checking database...
if not exist "%BACKEND%\data\" mkdir "%BACKEND%\data"

if not exist "%DB_FILE%" (
    echo        DB not found вҖ” running init_db.py to create + seed...
    cd /d "%BACKEND%"
    python scripts\init_db.py
    if errorlevel 1 (
        echo  [ERROR] init_db.py failed. Check Python installation.
        pause
        exit /b 1
    )
    echo        Database initialised successfully.
) else (
    echo        Database found: %DB_FILE%
)

:: в”Җв”Җ Step 2: Start FastAPI backend в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo.
echo  [2/4] Starting FastAPI backend  (http://localhost:8000)
echo         Logs will appear in the "API Server" window.
start "Crypto Sentinel вҖ” API Server" cmd /k ^
    "title Crypto Sentinel API ^& color 0B ^& cd /d %BACKEND% ^& echo. ^& echo  Starting Uvicorn... ^& echo. ^& python -m uvicorn api.main:app --reload --port 8000 --host 0.0.0.0 || (echo. ^& echo [ERROR] Uvicorn failed - check Python/deps ^& pause)"

:: в”Җв”Җ Wait for API to be ready (poll /api/health) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo  [3/4] Waiting for API to respond...
set /a TRIES=0
:WAIT_LOOP
timeout /t 2 /nobreak >nul
curl -s -o nul -w "%%{http_code}" http://localhost:8000/api/health 2>nul | findstr "200" >nul
if not errorlevel 1 (
    echo        API is online!
    goto API_READY
)
set /a TRIES+=1
if %TRIES% lss 15 (
    echo        Still waiting... ^(%TRIES%/15^)
    goto WAIT_LOOP
)
echo        API did not respond in time вҖ” starting UI anyway.

:API_READY

:: в”Җв”Җ Step 3: Start React dev server в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo.
echo  [4/4] Starting React UI  (http://localhost:5173)
start "Crypto Sentinel вҖ” UI Server" cmd /k ^
    "title Crypto Sentinel UI ^& color 0D ^& cd /d %FRONTEND% ^& echo. ^& echo  Starting Vite dev server... ^& echo. ^& npm run dev || (echo. ^& echo [ERROR] npm run dev failed - run 'npm install' first ^& pause)"

:: в”Җв”Җ Wait then open browser в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
timeout /t 4 /nobreak >nul
echo.
echo  в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo    UI   вҶ’  http://localhost:5173
echo    API  вҶ’  http://localhost:8000
echo    Docs вҶ’  http://localhost:8000/docs
echo  в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
echo.
echo  Opening browser...
start http://localhost:5173

echo.
echo  Both servers are running in separate windows.
echo  Close those windows to stop the servers.
echo.
pause
