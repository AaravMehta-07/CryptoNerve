# Reddit API (https://www.reddit.com/prefs/apps - create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=crypto-sentinel:v1.0 (by /u/your_username)

# NewsAPI (https://newsapi.org/register - free tier)
NEWS_API_KEY=your_newsapi_key

# Etherscan (https://etherscan.io/apis - free tier)
ETHERSCAN_API_KEY=your_etherscan_key

# Solscan (https://public-api.solscan.io - free, no key needed for basic)
# No key required for basic endpoints

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=crypto_sentinel
DB_USER=admin
DB_PASSWORD=sentinel_secure_2026

# Local LLM — GGUF path (auto-detected from ./models/ if not set)
# LLM_MODEL_PATH=/app/models/mistral-7b-instruct-v0.1.Q3_K_M.gguf
# Context window (tokens): 4096 is safe for Q3_K_M on 8 GB RAM
LLM_N_CTX=4096
# Threads for CPU inference (match your CPU core count)
LLM_N_THREADS=8
# GPU offload layers: 0 = CPU only, -1 = all layers on GPU (requires CUDA/Metal)
LLM_N_GPU_LAYERS=0

# Dashboard
STREAMLIT_PORT=8501
